                                                <Line X1="78" X2="1190"
                                                      Y1="{Binding Y}" Y2="{Binding Y}"
                                                      Stroke="{Binding Accent}"
                                                      StrokeThickness="1.2"
                                                      StrokeDashArray="4 4"
                                                      Opacity="0.65" />
                                                <Ellipse Canvas.Left="{Binding MarkerX}"
                                                         Canvas.Top="{Binding MarkerY}"
                                                         Width="8"
                                                         Height="8"
                                                         Fill="{Binding Accent}"
                                                         Stroke="White"
                                                         StrokeThickness="2" />
                                                <Border Canvas.Left="{Binding PanelX}"
                                                        Canvas.Top="{Binding PanelY}"
                                                        Width="300"
                                                        Background="#F8FAFC"
                                                        BorderBrush="{Binding Accent}"
                                                        BorderThickness="1.5"
                                                        CornerRadius="8"
                                                        Padding="14"
                                                        Opacity="0.98">
                                                    <TextBlock Text="{Binding Label}"
                                                               Foreground="#0F172A"
                                                               FontSize="15"
                                                               FontWeight="SemiBold"
                                                               FontFamily="Consolas"
