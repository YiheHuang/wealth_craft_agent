<Window x:Class="InvestAgent.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:navigation="clr-namespace:System.Windows.Navigation;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Wealth Craft Agent"
        Width="1440"
        Height="820"
        MinWidth="1200"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="#F3F6FB">
    <Window.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#0F172A" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#0F766E" />
            <Setter Property="BorderBrush" Value="#0F766E" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="ChartToggleButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="98" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>

        <Style x:Key="CanvasTickContainerStyle" TargetType="ContentPresenter">
            <Setter Property="Canvas.Left" Value="{Binding X}" />
            <Setter Property="Canvas.Top" Value="{Binding Y}" />
        </Style>

        <Style x:Key="CardTabItemStyle" TargetType="TabItem">
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="ListCardStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E6FFFA" />
                    <Setter Property="BorderBrush" Value="#14B8A6" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ChatBubbleStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="MaxWidth" Value="720" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsUser}" Value="True">
                    <Setter Property="HorizontalAlignment" Value="Right" />
                    <Setter Property="Background" Value="#DBEAFE" />
                    <Setter Property="BorderBrush" Value="#93C5FD" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DailyChartVisibilityStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowDailyChart}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DailyTableVisibilityStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowDailyChart}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MonthlyChartVisibilityStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowMonthlyChart}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MonthlyTableVisibilityStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowMonthlyChart}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}"
                Padding="18"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.1*" />
                    <ColumnDefinition Width="2.25*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,18,0">
                    <TextBlock Text="Wealth Craft Agent"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#0F172A" />
                    <TextBlock Margin="0,8,0,0"
                               Text="先建立股票会话，再在当前会话里持续追问，让 Agent A 协调 B/C/D 增量更新图表、新闻与财务。"
                               TextWrapping="Wrap"
                               Foreground="#475569"
                               FontSize="13" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,18,0">
                    <TextBlock Text="新建分析会话"
                               Style="{StaticResource SectionTitleStyle}" />
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="128" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}"
                                 Height="42"
                                 FontSize="15"
                                 VerticalContentAlignment="Center"
                                 Padding="12,0"
                                 BorderBrush="#CBD5E1"
                                 ToolTip="请输入股票代码或股票名称，例如 600519、贵州茅台、比亚迪" />
                        <Button Grid.Column="1"
                                Margin="10,0,0,0"
                                Height="42"
                                Content="开始分析"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding RunCommand}" />
                    </Grid>
                    <TextBlock Margin="0,8,0,0"
                               Text="这里只输入股票代码或股票名称；详细自然语言需求请在左下会话追问区继续。"
                               Style="{StaticResource MutedTextStyle}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="分析历史"
                               Style="{StaticResource SectionTitleStyle}" />

                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.05*" />
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ListBox Grid.Column="0"
                                 ItemsSource="{Binding HistoryGroups}"
                                 SelectedItem="{Binding SelectedHistoryGroup}"
                                 Height="108"
                                 Background="#F8FAFC"
                                 BorderBrush="#E2E8F0"
                                 BorderThickness="1"
                                 ItemContainerStyle="{StaticResource ListCardStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#0F172A" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="{Binding Sessions.Count, StringFormat=会话数：{0}}"
                                                   Foreground="#64748B"
                                                   FontSize="12" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ListBox Grid.Column="1"
                                 Margin="10,0,0,0"
                                 ItemsSource="{Binding VisibleHistorySessions}"
                                 SelectedItem="{Binding SelectedHistorySession}"
                                 Height="108"
                                 Background="#F8FAFC"
                                 BorderBrush="#E2E8F0"
                                 BorderThickness="1"
                                 ItemContainerStyle="{StaticResource ListCardStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding SessionTitle}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#0F172A"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="{Binding UpdatedAt, StringFormat=更新时间：{0:MM-dd HH:mm}}"
                                                   Foreground="#64748B"
                                                   FontSize="12" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Grid.Column="2" Margin="10,0,0,0" VerticalAlignment="Stretch">
                            <Button Content="刷新"
                                    Margin="0,0,0,8"
                                    Height="42"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding RefreshHistoryCommand}" />
                            <Button Content="加载"
                                    Height="42"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding LoadSelectedHistoryCommand}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.02*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1.18*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}"
                    Padding="14">
                <TabControl Background="Transparent"
                            BorderThickness="0">
                    <TabControl.Resources>
                        <Style BasedOn="{StaticResource CardTabItemStyle}" TargetType="TabItem" />
                    </TabControl.Resources>

                    <TabItem Header="LLM分析与总结">
                        <Grid Margin="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="#F8FAFC"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="14"
                                    Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="当前会话"
                                                   Style="{StaticResource MutedTextStyle}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding CurrentSessionLabel}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="#0F172A"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="18,0,0,0">
                                        <TextBlock Text="当前标的"
                                                   Style="{StaticResource MutedTextStyle}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding ResolvedSymbol}"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="#0F172A" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1"
                                    Background="#F8FAFC"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="14"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="主要业务"
                                               Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="{Binding MainBusiness}"
                                               TextWrapping="Wrap"
                                               Foreground="#0F172A"
                                               FontSize="14" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2"
                                    Background="#F8FAFC"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="14">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Text="最终分析与风险提示"
                                                   Style="{StaticResource SectionTitleStyle}" />
                                        <TextBlock Margin="0,12,0,0"
                                                   Text="{Binding FinalResponse}"
                                                   TextWrapping="Wrap"
                                                   Foreground="#0F172A"
                                                   FontSize="14" />
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Agent步骤流">
                        <Border Margin="4"
                                Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="12">
                            <ListBox ItemsSource="{Binding Steps}"
                                     Background="Transparent"
                                     BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12"
                                                Padding="14"
                                                Background="White"
                                                BorderBrush="#E2E8F0"
                                                BorderThickness="1"
                                                CornerRadius="12">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold"
                                                           FontSize="14"
                                                           Foreground="#0F172A" />
                                                <TextBox Margin="0,10,0,0"
                                                         Text="{Binding Content}"
                                                         TextWrapping="Wrap"
                                                         AcceptsReturn="True"
                                                         IsReadOnly="True"
                                                         BorderThickness="0"
                                                         Background="Transparent"
                                                         VerticalScrollBarVisibility="Disabled" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </TabItem>

                    <TabItem Header="会话内追问">
                        <Grid Margin="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="#F8FAFC"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="16">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ChatMessages}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource ChatBubbleStyle}">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding RoleLabel}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#0F172A" />
                                                        <TextBlock Margin="0,8,0,0"
                                                                   Text="{Binding Content}"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="#0F172A"
                                                                   FontSize="14" />
                                                        <TextBlock Margin="0,8,0,0"
                                                                   Text="{Binding Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                                                   Foreground="#64748B"
                                                                   FontSize="11" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>

                            <Grid Grid.Row="1" Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         MinHeight="88"
                                         MaxHeight="140"
                                         Text="{Binding ChatInput, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Padding="14"
                                         BorderBrush="#CBD5E1"
                                         ToolTip="例如：用缠论分析一下；我想看最近一年的日K线图；只看消极新闻" />
                                <Button Grid.Column="1"
                                        Margin="12,0,0,0"
                                        Content="发送追问"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding SendChatCommand}" />
                            </Grid>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource CardBorderStyle}"
                    Padding="14">
                <TabControl Background="Transparent"
                            BorderThickness="0">
                <TabControl.Resources>
                    <Style BasedOn="{StaticResource CardTabItemStyle}" TargetType="TabItem" />
                </TabControl.Resources>

                <TabItem Header="近一年月K线">
                    <Grid Margin="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="近一年月K线完整数据"
                                       Style="{StaticResource SectionTitleStyle}"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Content="图表 / 表格"
                                    Style="{StaticResource ChartToggleButtonStyle}"
                                    Margin="12,0,0,0"
                                    Command="{Binding ToggleMonthlyViewCommand}" />
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid Style="{StaticResource MonthlyChartVisibilityStyle}">
                                <Border Background="#F8FAFC"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="10"
                                        MinHeight="400">
                                    <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                                        <Canvas Width="1220" Height="420">
                                            <Line X1="78" Y1="28" X2="78" Y2="354" Stroke="#94A3B8" StrokeThickness="1.2" />
                                            <Line X1="78" Y1="354" X2="1190" Y2="354" Stroke="#94A3B8" StrokeThickness="1.2" />

                                            <ItemsControl ItemsSource="{Binding MonthlySegments}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Line X1="{Binding X1}" Y1="{Binding Y1}" X2="{Binding X2}" Y2="{Binding Y2}" Stroke="{Binding Stroke}" StrokeThickness="2" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <ItemsControl ItemsSource="{Binding MonthlyYTicks}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style BasedOn="{StaticResource CanvasTickContainerStyle}" TargetType="ContentPresenter" />
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Label}" Foreground="#334155" FontSize="13" FontWeight="SemiBold" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <ItemsControl ItemsSource="{Binding MonthlyXTicks}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style BasedOn="{StaticResource CanvasTickContainerStyle}" TargetType="ContentPresenter" />
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Label}" Foreground="#334155" FontSize="12" FontWeight="SemiBold" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <ItemsControl ItemsSource="{Binding MonthlyPoints}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style BasedOn="{StaticResource CanvasTickContainerStyle}" TargetType="ContentPresenter" />
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Width="{Binding Diameter}"
                                                              Height="{Binding Diameter}"
                                                              Background="Transparent"
                                                              ToolTip="{Binding ToolTip}">
                                                            <Ellipse x:Name="MonthlyPointDot"
                                                                     Width="12"
                                                                     Height="12"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center"
                                                                     Fill="{Binding Fill}"
                                                                     Stroke="White"
                                                                     StrokeThickness="1.8" />
                                                        </Grid>
                                                        <DataTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Grid}, Path=IsMouseOver}" Value="True">
                                                                <Setter TargetName="MonthlyPointDot" Property="Width" Value="18" />
                                                                <Setter TargetName="MonthlyPointDot" Property="Height" Value="18" />
                                                                <Setter TargetName="MonthlyPointDot" Property="StrokeThickness" Value="2.4" />
                                                            </DataTrigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock Text="价格"
                                                       Foreground="#64748B"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Canvas.Left="42"
                                                       Canvas.Top="2" />
                                            <TextBlock Text="时间"
                                                       Foreground="#64748B"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Canvas.Left="590"
                                                       Canvas.Top="392" />
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                            </Grid>

                            <Grid Style="{StaticResource MonthlyTableVisibilityStyle}">
                                <DataGrid ItemsSource="{Binding MonthlyKLines}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="日期" Binding="{Binding Date, StringFormat=yyyy-MM-dd}" Width="*" />
                                        <DataGridTextColumn Header="开盘" Binding="{Binding Open}" Width="*" />
                                        <DataGridTextColumn Header="最高" Binding="{Binding High}" Width="*" />
                                        <DataGridTextColumn Header="最低" Binding="{Binding Low}" Width="*" />
                                        <DataGridTextColumn Header="收盘" Binding="{Binding Close}" Width="*" />
                                        <DataGridTextColumn Header="成交量" Binding="{Binding Volume}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="近三个月日K线">
                    <Grid Margin="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="近三个月日K线完整数据"
                                       Style="{StaticResource SectionTitleStyle}"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Content="图表 / 表格"
                                    Style="{StaticResource ChartToggleButtonStyle}"
                                    Margin="12,0,0,0"
                                    Command="{Binding ToggleDailyViewCommand}" />
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid Style="{StaticResource DailyChartVisibilityStyle}">
                                <Border Background="#F8FAFC"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="10"
                                        MinHeight="400">
                                    <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                                        <Canvas Width="1220" Height="420">
                                            <Line X1="78" Y1="28" X2="78" Y2="354" Stroke="#94A3B8" StrokeThickness="1.2" />
                                            <Line X1="78" Y1="354" X2="1190" Y2="354" Stroke="#94A3B8" StrokeThickness="1.2" />

                                            <ItemsControl ItemsSource="{Binding DailySegments}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Line X1="{Binding X1}" Y1="{Binding Y1}" X2="{Binding X2}" Y2="{Binding Y2}" Stroke="{Binding Stroke}" StrokeThickness="2" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <ItemsControl ItemsSource="{Binding DailyYTicks}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style BasedOn="{StaticResource CanvasTickContainerStyle}" TargetType="ContentPresenter" />
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Label}" Foreground="#334155" FontSize="13" FontWeight="SemiBold" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <ItemsControl ItemsSource="{Binding DailyXTicks}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style BasedOn="{StaticResource CanvasTickContainerStyle}" TargetType="ContentPresenter" />
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Label}" Foreground="#334155" FontSize="12" FontWeight="SemiBold" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <ItemsControl ItemsSource="{Binding DailyPoints}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style BasedOn="{StaticResource CanvasTickContainerStyle}" TargetType="ContentPresenter" />
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Width="{Binding Diameter}"
                                                              Height="{Binding Diameter}"
                                                              Background="Transparent"
                                                              ToolTip="{Binding ToolTip}">
                                                            <Ellipse x:Name="DailyPointDot"
                                                                     Width="12"
                                                                     Height="12"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center"
                                                                     Fill="{Binding Fill}"
                                                                     Stroke="White"
                                                                     StrokeThickness="1.8" />
                                                        </Grid>
                                                        <DataTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Grid}, Path=IsMouseOver}" Value="True">
                                                                <Setter TargetName="DailyPointDot" Property="Width" Value="18" />
                                                                <Setter TargetName="DailyPointDot" Property="Height" Value="18" />
                                                                <Setter TargetName="DailyPointDot" Property="StrokeThickness" Value="2.4" />
                                                            </DataTrigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock Text="价格"
                                                       Foreground="#64748B"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Canvas.Left="42"
                                                       Canvas.Top="2" />
                                            <TextBlock Text="时间"
                                                       Foreground="#64748B"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Canvas.Left="590"
                                                       Canvas.Top="392" />
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                            </Grid>

                            <Grid Style="{StaticResource DailyTableVisibilityStyle}">
                                <DataGrid ItemsSource="{Binding DailyKLines}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="日期" Binding="{Binding Date, StringFormat=yyyy-MM-dd}" Width="*" />
                                        <DataGridTextColumn Header="开盘" Binding="{Binding Open}" Width="*" />
                                        <DataGridTextColumn Header="最高" Binding="{Binding High}" Width="*" />
                                        <DataGridTextColumn Header="最低" Binding="{Binding Low}" Width="*" />
                                        <DataGridTextColumn Header="收盘" Binding="{Binding Close}" Width="*" />
                                        <DataGridTextColumn Header="成交量" Binding="{Binding Volume}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="新闻动态">
                    <Grid Margin="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="公司新闻"
                                           Style="{StaticResource SectionTitleStyle}" />
                                <ListBox Grid.Row="1"
                                         Margin="0,12,0,0"
                                         ItemsSource="{Binding CompanyNewsItems}"
                                         Background="Transparent"
                                         BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10"
                                                    Padding="12"
                                                    Background="White"
                                                    BorderBrush="#E2E8F0"
                                                    BorderThickness="1"
                                                    CornerRadius="12">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding PublishTime, StringFormat=yyyy-MM-dd HH:mm}"
                                                               Foreground="#64748B"
                                                               FontSize="11" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               FontSize="13"
                                                               TextWrapping="Wrap">
                                                        <Hyperlink NavigateUri="{Binding Url}" RequestNavigate="NewsLink_RequestNavigate">
                                                            <Run Text="{Binding Title}" />
                                                        </Hyperlink>
                                                    </TextBlock>
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="{Binding Source}"
                                                               Foreground="#0F766E"
                                                               FontSize="12" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="{Binding Summary}"
                                                               TextWrapping="Wrap"
                                                               Foreground="#334155"
                                                               FontSize="12" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                                Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="行业新闻"
                                           Style="{StaticResource SectionTitleStyle}" />
                                <ListBox Grid.Row="1"
                                         Margin="0,12,0,0"
                                         ItemsSource="{Binding IndustryNewsItems}"
                                         Background="Transparent"
                                         BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10"
                                                    Padding="12"
                                                    Background="White"
                                                    BorderBrush="#E2E8F0"
                                                    BorderThickness="1"
                                                    CornerRadius="12">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding PublishTime, StringFormat=yyyy-MM-dd HH:mm}"
                                                               Foreground="#64748B"
                                                               FontSize="11" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               FontSize="13"
                                                               TextWrapping="Wrap">
                                                        <Hyperlink NavigateUri="{Binding Url}" RequestNavigate="NewsLink_RequestNavigate">
                                                            <Run Text="{Binding Title}" />
                                                        </Hyperlink>
                                                    </TextBlock>
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="{Binding Source}"
                                                               Foreground="#0F766E"
                                                               FontSize="12" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="{Binding Summary}"
                                                               TextWrapping="Wrap"
                                                               Foreground="#334155"
                                                               FontSize="12" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="财务情况">
                    <Grid Margin="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14"
                                Margin="0,0,0,10">
                            <TextBlock Text="{Binding MetricsSummary}"
                                       TextWrapping="Wrap"
                                       Foreground="#0F172A"
                                       FontSize="13" />
                        </Border>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding FinancialHistoryItems}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="报告期" Binding="{Binding ReportDate, StringFormat=yyyy-MM-dd}" Width="*" />
                                <DataGridTextColumn Header="ROE" Binding="{Binding ROE, StringFormat=F2}" Width="*" />
                                <DataGridTextColumn Header="ROA" Binding="{Binding ROA, StringFormat=F2}" Width="*" />
                                <DataGridTextColumn Header="毛利率" Binding="{Binding GrossMargin, StringFormat=F2}" Width="*" />
                                <DataGridTextColumn Header="净利率" Binding="{Binding NetMargin, StringFormat=F2}" Width="*" />
                                <DataGridTextColumn Header="营收增长" Binding="{Binding RevenueGrowth, StringFormat=F2}" Width="*" />
                                <DataGridTextColumn Header="净利增长" Binding="{Binding ProfitGrowth, StringFormat=F2}" Width="*" />
                                <DataGridTextColumn Header="资产负债率" Binding="{Binding DebtRatio, StringFormat=F2}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
        </Grid>
    </Grid>
</Window>
