<Window x:Class="InvestAgent.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:navigation="clr-namespace:System.Windows.Navigation;assembly=PresentationFramework"
        xmlns:converters="clr-namespace:InvestAgent.Desktop.Converters"
        mc:Ignorable="d"
        Title="Wealth Craft Agent"
        Width="1440"
        Height="820"
        MinWidth="1200"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/app.ico"
        Background="#F3F6FB">
    <Window.Resources>
        <converters:MarkdownToFlowDocumentConverter x:Key="MarkdownToFlowDocumentConverter" />

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#0F172A" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#0F766E" />
            <Setter Property="BorderBrush" Value="#0F766E" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="ChartToggleButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="98" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>

        <Style x:Key="RangeShortcutButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Height" Value="26" />
            <Setter Property="MinWidth" Value="48" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <Style x:Key="CanvasTickContainerStyle" TargetType="ContentPresenter">
            <Setter Property="Canvas.Left" Value="{Binding X}" />
            <Setter Property="Canvas.Top" Value="{Binding Y}" />
        </Style>

        <Style x:Key="CandleContainerStyle" TargetType="ContentPresenter">
            <Setter Property="Canvas.Left" Value="{Binding X}" />
            <Setter Property="Canvas.Top" Value="0" />
        </Style>

        <Style x:Key="ChartHoverOverlayStyle" TargetType="Canvas">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsVisible}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardTabItemStyle" TargetType="TabItem">
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="ListCardStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E6FFFA" />
                    <Setter Property="BorderBrush" Value="#14B8A6" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ChatBubbleStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsUser}" Value="True">
                    <Setter Property="HorizontalAlignment" Value="Right" />
                    <Setter Property="MaxWidth" Value="360" />
                    <Setter Property="Margin" Value="0,0,0,10" />
                    <Setter Property="Background" Value="#DBEAFE" />
                    <Setter Property="BorderBrush" Value="#93C5FD" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DailyChartVisibilityStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowDailyChart}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DailyTableVisibilityStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowDailyChart}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MonthlyChartVisibilityStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowMonthlyChart}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MonthlyTableVisibilityStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowMonthlyChart}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="UserOnlyVisibilityStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsUser}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AgentOnlyVisibilityStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsUser}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}"
                Padding="14"
                Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="2.6*" />
                    <ColumnDefinition Width="1.8*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,18,0" VerticalAlignment="Center">
                    <TextBlock Text="Wealth Craft Agent"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#0F172A" />
                    <TextBlock Margin="0,4,0,0"
                               Text="{Binding StatusText}"
                               Style="{StaticResource MutedTextStyle}" />
                </StackPanel>

                <Grid Grid.Column="1" Margin="0,0,18,0" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Margin="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="132" />
                            <ColumnDefinition Width="128" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}"
                                 Height="42"
                                 FontSize="15"
                                 VerticalContentAlignment="Center"
                                 Padding="12,0"
                                 BorderBrush="#CBD5E1"
                                 ToolTip="请输入股票代码或股票名称，例如 600519、贵州茅台、比亚迪" />
                        <StackPanel Grid.Column="1"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="日K显示范围"
                                       Style="{StaticResource MutedTextStyle}" />
                            <TextBox Text="{Binding DailyDaysInputText, UpdateSourceTrigger=PropertyChanged}"
                                     Height="24"
                                     Margin="0,4,0,0"
                                     Padding="6,0"
                                     VerticalContentAlignment="Center"
                                     ToolTip="只调整日K图表和表格显示范围，不会自动触发AI重新分析" />
                        </StackPanel>
                        <StackPanel Grid.Column="2"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="月K显示范围"
                                       Style="{StaticResource MutedTextStyle}" />
                            <TextBox Text="{Binding MonthlyMonthsInputText, UpdateSourceTrigger=PropertyChanged}"
                                     Height="24"
                                     Margin="0,4,0,0"
                                     Padding="6,0"
                                     VerticalContentAlignment="Center"
                                     ToolTip="只调整月K图表和表格显示范围，不会自动触发AI重新分析" />
                        </StackPanel>
                        <Button Grid.Column="3"
                                Margin="10,0,0,0"
                                Height="42"
                                Content="开始分析"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding RunCommand}" />
                    </Grid>
                </Grid>

                <Button Grid.Column="2"
                        x:Name="HistoryMenuButton"
                        Content="分析历史"
                        Height="42"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Padding="16,8"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="HistoryMenuButton_Click">
                    <Button.ContextMenu>
                        <ContextMenu x:Name="HistoryContextMenu"
                                     Placement="Bottom"
                                     PlacementTarget="{Binding ElementName=HistoryMenuButton}" />
                    </Button.ContextMenu>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1.05*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}"
                    Padding="14">
                <TabControl Background="Transparent"
                            BorderThickness="0">
                    <TabControl.Resources>
                        <Style BasedOn="{StaticResource CardTabItemStyle}" TargetType="TabItem" />
                    </TabControl.Resources>

                    <TabItem Header="基本情况分析">
                        <Grid Margin="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="#F8FAFC"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="14"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="当前会话"
                                               Style="{StaticResource MutedTextStyle}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding CurrentSessionDisplay}"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="#0F172A"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1"
                                    Background="#F8FAFC"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="14">
                                <FlowDocumentScrollViewer x:Name="BasicAnalysisScrollViewer"
                                                          VerticalScrollBarVisibility="Visible"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          PreviewMouseWheel="FlowDocumentScrollViewer_PreviewMouseWheel"
                                                          MouseEnter="AutoHideScrollViewer_MouseEnter"
                                                          MouseLeave="AutoHideScrollViewer_MouseLeave"
                                                          Loaded="FlowDocumentScrollViewer_Loaded"
                                                          SizeChanged="FlowDocumentScrollViewer_SizeChanged"
                                                          LayoutUpdated="FlowDocumentScrollViewer_LayoutUpdated"
                                                          IsToolBarVisible="False"
                                                          Document="{Binding BasicAnalysisResponse, Converter={StaticResource MarkdownToFlowDocumentConverter}}" />
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Agent步骤流">
                        <Border Margin="4"
                                Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="12">
                            <ListBox ItemsSource="{Binding Steps}"
                                     Background="Transparent"
                                     BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12"
                                                Padding="14"
                                                Background="White"
                                                BorderBrush="#E2E8F0"
                                                BorderThickness="1"
                                                CornerRadius="12">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold"
                                                           FontSize="14"
                                                           Foreground="#0F172A" />
                                                <TextBox Margin="0,10,0,0"
                                                         Text="{Binding Content}"
                                                         TextWrapping="Wrap"
                                                         AcceptsReturn="True"
                                                         IsReadOnly="True"
                                                         BorderThickness="0"
                                                         Background="Transparent"
                                                         VerticalScrollBarVisibility="Disabled" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </TabItem>

                    <TabItem Header="会话内追问">
                        <Grid Margin="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="#F8FAFC"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="16">
                                <ScrollViewer x:Name="ChatScrollViewer"
                                              PreviewMouseWheel="ChatScrollViewer_PreviewMouseWheel"
                                              Loaded="AutoHideScrollViewer_Loaded"
                                              MouseEnter="AutoHideScrollViewer_MouseEnter"
                                              MouseLeave="AutoHideScrollViewer_MouseLeave"
                                              VerticalScrollBarVisibility="Visible"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <Grid>
                                        <ItemsControl ItemsSource="{Binding ChatMessages}"
                                                      HorizontalAlignment="Stretch">
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid HorizontalAlignment="Stretch">
                                                        <Border Style="{StaticResource ChatBubbleStyle}">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding RoleLabel}"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#0F172A" />
                                                                <TextBlock Margin="0,8,0,0"
                                                                           Text="{Binding Content}"
                                                                           TextWrapping="Wrap"
                                                                           Foreground="#0F172A"
                                                                           FontSize="14"
                                                                           Style="{StaticResource UserOnlyVisibilityStyle}" />
                                                                <FlowDocumentScrollViewer Margin="0,8,0,0"
                                                                                          IsToolBarVisible="False"
                                                                                          VerticalScrollBarVisibility="Hidden"
                                                                                          HorizontalScrollBarVisibility="Disabled"
                                                                                          PreviewMouseWheel="FlowDocumentScrollViewer_PreviewMouseWheel"
                                                                                          Loaded="FlowDocumentScrollViewer_Loaded"
                                                                                          SizeChanged="FlowDocumentScrollViewer_SizeChanged"
                                                                                          LayoutUpdated="FlowDocumentScrollViewer_LayoutUpdated"
                                                                                          Document="{Binding Content, Converter={StaticResource MarkdownToFlowDocumentConverter}}"
                                                                                          Style="{StaticResource AgentOnlyVisibilityStyle}" />
                                                                <TextBlock Margin="0,8,0,0"
                                                                           Text="{Binding Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                                                           Foreground="#64748B"
                                                                           FontSize="11" />
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </ScrollViewer>
                            </Border>

                            <Grid Grid.Row="1" Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         MinHeight="88"
                                         MaxHeight="140"
                                         Text="{Binding ChatInput, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         PreviewKeyDown="ChatInputTextBox_PreviewKeyDown"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Padding="14"
                                         BorderBrush="#CBD5E1"
                                         ToolTip="例如：用缠论分析一下；我想看最近一年的日K线图；只看消极新闻" />
                                <Button Grid.Column="1"
                                        Margin="12,0,0,0"
                                        Content="发送追问"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding SendChatCommand}" />
                            </Grid>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource CardBorderStyle}"
                    Padding="14">
                <TabControl Background="Transparent"
                            BorderThickness="0">
                <TabControl.Resources>
                    <Style BasedOn="{StaticResource CardTabItemStyle}" TargetType="TabItem" />
                </TabControl.Resources>

                <TabItem Header="{Binding MonthlyTabTitle}">
                    <Grid Margin="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding MonthlyChartTitle}"
                                           Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="{Binding MonthlyChartWindowLabel}"
                                           Style="{StaticResource MutedTextStyle}" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="{Binding KLineAnalysisRangeLabel}"
                                           Style="{StaticResource MutedTextStyle}" />
                                <WrapPanel Margin="0,7,0,0">
                                    <Button Content="6月"
                                            Command="{Binding SetMonthlyRangeCommand}"
                                            CommandParameter="6"
                                            Style="{StaticResource RangeShortcutButtonStyle}" />
                                    <Button Content="12月"
                                            Command="{Binding SetMonthlyRangeCommand}"
                                            CommandParameter="12"
                                            Style="{StaticResource RangeShortcutButtonStyle}" />
                                    <Button Content="24月"
                                            Command="{Binding SetMonthlyRangeCommand}"
                                            CommandParameter="24"
                                            Style="{StaticResource RangeShortcutButtonStyle}" />
                                    <Button Content="36月"
                                            Command="{Binding SetMonthlyRangeCommand}"
                                            CommandParameter="36"
                                            Style="{StaticResource RangeShortcutButtonStyle}" />
                                    <Button Content="60月"
                                            Command="{Binding SetMonthlyRangeCommand}"
                                            CommandParameter="60"
                                            Style="{StaticResource RangeShortcutButtonStyle}" />
                                    <Button Content="120月"
                                            Command="{Binding SetMonthlyRangeCommand}"
                                            CommandParameter="120"
                                            Style="{StaticResource RangeShortcutButtonStyle}" />
                                </WrapPanel>
                                <Grid Margin="0,10,0,0"
                                      Width="560"
                                      MaxWidth="560"
                                      HorizontalAlignment="Left">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="76" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="范围调节"
                                               Margin="0,0,12,0"
                                               VerticalAlignment="Center"
                                               Style="{StaticResource MutedTextStyle}" />
                                    <Slider Grid.Column="1"
                                            Height="28"
                                            Minimum="1"
                                            Maximum="180"
                                            TickFrequency="1"
                                            SmallChange="1"
                                            LargeChange="12"
                                            IsSnapToTickEnabled="True"
                                            Value="{Binding MonthlyMonthsInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding MonthlyMonthsInput, StringFormat={}{0}月}"
                                               Margin="12,0,0,0"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#475569" />
                                </Grid>
                                <WrapPanel Margin="0,7,0,0"
                                           VerticalAlignment="Center">
                                    <WrapPanel.Style>
                                        <Style TargetType="WrapPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsKLineRangeNoticeVisible}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </WrapPanel.Style>
                                    <TextBlock Text="{Binding KLineRangeNotice}"
                                               Foreground="#A16207"
                                               FontSize="12"
                                               Margin="0,0,10,4"
                                               VerticalAlignment="Center" />
                                    <Button Content="按当前图表重新分析"
                                            MinWidth="168"
                                            Height="32"
                                            Margin="0,0,0,4"
                                            Padding="12,4"
                                            FontSize="12"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding ReanalyzeCurrentChartRangeCommand}" />
                                </WrapPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <Button Content="重置"
                                        Height="32"
                                        MinWidth="58"
                                        ToolTip="恢复显示全部"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding ResetMonthlyChartCommand}" />
                                <Button Content="图表 / 表格"
                                        Style="{StaticResource ChartToggleButtonStyle}"
                                        Margin="10,0,0,0"
                                        Command="{Binding ToggleMonthlyViewCommand}" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid Style="{StaticResource MonthlyChartVisibilityStyle}">
                                <Border Background="#F8FAFC"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="10"
                                        MinHeight="400">
                                    <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                                        <Canvas x:Name="MonthlyChartCanvas"
                                                Width="1220"
                                                Height="420"
                                                Background="Transparent"
                                                Cursor="SizeWE"
                                                PreviewMouseWheel="MonthlyChartCanvas_PreviewMouseWheel"
                                                PreviewMouseLeftButtonDown="MonthlyChartCanvas_PreviewMouseLeftButtonDown"
                                                PreviewMouseLeftButtonUp="ChartCanvas_PreviewMouseLeftButtonUp"
                                                PreviewMouseMove="MonthlyChartCanvas_PreviewMouseMove"
                                                MouseLeave="MonthlyChartCanvas_MouseLeave"
                                                LostMouseCapture="ChartCanvas_LostMouseCapture">
                                            <Line X1="78" Y1="28" X2="78" Y2="354" Stroke="#94A3B8" StrokeThickness="1.2" />
                                            <Line X1="78" Y1="354" X2="1190" Y2="354" Stroke="#94A3B8" StrokeThickness="1.2" />

                                            <ItemsControl ItemsSource="{Binding MonthlyCandles}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style BasedOn="{StaticResource CandleContainerStyle}" TargetType="ContentPresenter" />
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Canvas Width="{Binding BodyWidth}"
                                                                Height="420"
                                                                Background="Transparent"
                                                                Cursor="SizeWE">
                                                            <Line X1="{Binding WickOffset}"
                                                                  X2="{Binding WickOffset}"
                                                                  Y1="{Binding WickTop}"
                                                                  Y2="{Binding WickBottom}"
                                                                  Stroke="{Binding Stroke}"
                                                                  StrokeThickness="1.4" />
                                                            <Rectangle Canvas.Top="{Binding BodyY}"
                                                                       Width="{Binding BodyWidth}"
                                                                       Height="{Binding BodyHeight}"
                                                                       Fill="{Binding Fill}"
                                                                       Stroke="{Binding Stroke}"
                                                                       StrokeThickness="1.2" />
                                                        </Canvas>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <ItemsControl ItemsSource="{Binding MonthlyYTicks}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style BasedOn="{StaticResource CanvasTickContainerStyle}" TargetType="ContentPresenter" />
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Label}" Foreground="#334155" FontSize="13" FontWeight="SemiBold" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <ItemsControl ItemsSource="{Binding MonthlyXTicks}">
