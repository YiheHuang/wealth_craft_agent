                                                       Canvas.Top="2" />
                                            <TextBlock Text="时间"
                                                       Foreground="#64748B"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Canvas.Left="590"
                                                       Canvas.Top="392" />

                                            <Canvas Width="1220"
                                                    Height="420"
