                                                               LineHeight="24" />
                                                </Border>
                                            </Canvas>
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                            </Grid>

                            <Grid Style="{StaticResource MonthlyTableVisibilityStyle}">
                                <DataGrid ItemsSource="{Binding MonthlyKLines}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="日期" Binding="{Binding Date, StringFormat=yyyy-MM-dd}" Width="*" />
                                        <DataGridTextColumn Header="开盘" Binding="{Binding Open}" Width="*" />
                                        <DataGridTextColumn Header="最高" Binding="{Binding High}" Width="*" />
                                        <DataGridTextColumn Header="最低" Binding="{Binding Low}" Width="*" />
                                        <DataGridTextColumn Header="收盘" Binding="{Binding Close}" Width="*" />
                                        <DataGridTextColumn Header="成交量" Binding="{Binding Volume}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="{Binding DailyTabTitle}">
                    <Grid Margin="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DailyChartTitle}"
                                           Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="{Binding DailyChartWindowLabel}"
                                           Style="{StaticResource MutedTextStyle}" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="{Binding KLineAnalysisRangeLabel}"
                                           Style="{StaticResource MutedTextStyle}" />
                                <WrapPanel Margin="0,7,0,0">
                                    <Button Content="30日"
                                            Command="{Binding SetDailyRangeCommand}"
                                            CommandParameter="30"
                                            Style="{StaticResource RangeShortcutButtonStyle}" />
                                    <Button Content="60日"
                                            Command="{Binding SetDailyRangeCommand}"
                                            CommandParameter="60"
                                            Style="{StaticResource RangeShortcutButtonStyle}" />
                                    <Button Content="90日"
                                            Command="{Binding SetDailyRangeCommand}"
                                            CommandParameter="90"
                                            Style="{StaticResource RangeShortcutButtonStyle}" />
                                    <Button Content="200日"
                                            Command="{Binding SetDailyRangeCommand}"
                                            CommandParameter="200"
                                            Style="{StaticResource RangeShortcutButtonStyle}" />
                                    <Button Content="1年"
                                            Command="{Binding SetDailyRangeCommand}"
                                            CommandParameter="250"
                                            Style="{StaticResource RangeShortcutButtonStyle}" />
                                    <Button Content="3年"
                                            Command="{Binding SetDailyRangeCommand}"
                                            CommandParameter="750"
                                            Style="{StaticResource RangeShortcutButtonStyle}" />
                                    <Button Content="5年"
                                            Command="{Binding SetDailyRangeCommand}"
                                            CommandParameter="1200"
                                            Style="{StaticResource RangeShortcutButtonStyle}" />
                                </WrapPanel>
                                <Grid Margin="0,10,0,0"
                                      Width="620"
                                      MaxWidth="620"
                                      HorizontalAlignment="Left">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="84" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="范围调节"
                                               Margin="0,0,12,0"
                                               VerticalAlignment="Center"
                                               Style="{StaticResource MutedTextStyle}" />
                                    <Slider Grid.Column="1"
                                            Height="28"
                                            Minimum="5"
                                            Maximum="1200"
                                            TickFrequency="5"
                                            SmallChange="5"
                                            LargeChange="50"
                                            IsSnapToTickEnabled="True"
                                            Value="{Binding DailyDaysInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding DailyDaysInput, StringFormat={}{0}日}"
                                               Margin="12,0,0,0"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#475569" />
                                </Grid>
                                <WrapPanel Margin="0,7,0,0"
                                           VerticalAlignment="Center">
                                    <WrapPanel.Style>
                                        <Style TargetType="WrapPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsKLineRangeNoticeVisible}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </WrapPanel.Style>
                                    <TextBlock Text="{Binding KLineRangeNotice}"
                                               Foreground="#A16207"
                                               FontSize="12"
                                               Margin="0,0,10,4"
                                               VerticalAlignment="Center" />
                                    <Button Content="按当前图表重新分析"
                                            MinWidth="168"
                                            Height="32"
                                            Margin="0,0,0,4"
                                            Padding="12,4"
                                            FontSize="12"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding ReanalyzeCurrentChartRangeCommand}" />
                                </WrapPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <Button Content="重置"
                                        Height="32"
                                        MinWidth="58"
                                        ToolTip="恢复显示全部"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding ResetDailyChartCommand}" />
                                <Button Content="图表 / 表格"
                                        Style="{StaticResource ChartToggleButtonStyle}"
                                        Margin="10,0,0,0"
                                        Command="{Binding ToggleDailyViewCommand}" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid Style="{StaticResource DailyChartVisibilityStyle}">
                                <Border Background="#F8FAFC"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="10"
                                        MinHeight="400">
                                    <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                                        <Canvas x:Name="DailyChartCanvas"
                                                Width="1220"
                                                Height="420"
                                                Background="Transparent"
                                                Cursor="SizeWE"
                                                PreviewMouseWheel="DailyChartCanvas_PreviewMouseWheel"
                                                PreviewMouseLeftButtonDown="DailyChartCanvas_PreviewMouseLeftButtonDown"
                                                PreviewMouseLeftButtonUp="ChartCanvas_PreviewMouseLeftButtonUp"
                                                PreviewMouseMove="DailyChartCanvas_PreviewMouseMove"
                                                MouseLeave="DailyChartCanvas_MouseLeave"
                                                LostMouseCapture="ChartCanvas_LostMouseCapture">
                                            <Line X1="78" Y1="28" X2="78" Y2="354" Stroke="#94A3B8" StrokeThickness="1.2" />
                                            <Line X1="78" Y1="354" X2="1190" Y2="354" Stroke="#94A3B8" StrokeThickness="1.2" />

                                            <ItemsControl ItemsSource="{Binding DailyCandles}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style BasedOn="{StaticResource CandleContainerStyle}" TargetType="ContentPresenter" />
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Canvas Width="{Binding BodyWidth}"
                                                                Height="420"
                                                                Background="Transparent"
                                                                Cursor="SizeWE">
                                                            <Line X1="{Binding WickOffset}"
                                                                  X2="{Binding WickOffset}"
                                                                  Y1="{Binding WickTop}"
                                                                  Y2="{Binding WickBottom}"
                                                                  Stroke="{Binding Stroke}"
                                                                  StrokeThickness="1.4" />
                                                            <Rectangle Canvas.Top="{Binding BodyY}"
                                                                       Width="{Binding BodyWidth}"
                                                                       Height="{Binding BodyHeight}"
                                                                       Fill="{Binding Fill}"
                                                                       Stroke="{Binding Stroke}"
                                                                       StrokeThickness="1.2" />
                                                        </Canvas>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <ItemsControl ItemsSource="{Binding DailyYTicks}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style BasedOn="{StaticResource CanvasTickContainerStyle}" TargetType="ContentPresenter" />
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Label}" Foreground="#334155" FontSize="13" FontWeight="SemiBold" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <ItemsControl ItemsSource="{Binding DailyXTicks}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style BasedOn="{StaticResource CanvasTickContainerStyle}" TargetType="ContentPresenter" />
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Label}" Foreground="#334155" FontSize="12" FontWeight="SemiBold" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock Text="价格"
                                                       Foreground="#64748B"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Canvas.Left="42"
                                                       Canvas.Top="2" />
                                            <TextBlock Text="时间"
                                                       Foreground="#64748B"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Canvas.Left="590"
                                                       Canvas.Top="392" />

                                            <Canvas Width="1220"
                                                    Height="420"
                                                    DataContext="{Binding DailyChartHover}"
                                                    Style="{StaticResource ChartHoverOverlayStyle}">
                                                <Line X1="{Binding X}" X2="{Binding X}"
                                                      Y1="28" Y2="354"
                                                      Stroke="{Binding Accent}"
                                                      StrokeThickness="1.2"
                                                      StrokeDashArray="4 4"
                                                      Opacity="0.65" />
                                                <Line X1="78" X2="1190"
                                                      Y1="{Binding Y}" Y2="{Binding Y}"
                                                      Stroke="{Binding Accent}"
                                                      StrokeThickness="1.2"
                                                      StrokeDashArray="4 4"
                                                      Opacity="0.65" />
                                                <Ellipse Canvas.Left="{Binding MarkerX}"
                                                         Canvas.Top="{Binding MarkerY}"
                                                         Width="8"
                                                         Height="8"
                                                         Fill="{Binding Accent}"
                                                         Stroke="White"
                                                         StrokeThickness="2" />
                                                <Border Canvas.Left="{Binding PanelX}"
                                                        Canvas.Top="{Binding PanelY}"
                                                        Width="300"
                                                        Background="#F8FAFC"
                                                        BorderBrush="{Binding Accent}"
                                                        BorderThickness="1.5"
                                                        CornerRadius="8"
                                                        Padding="14"
                                                        Opacity="0.98">
                                                    <TextBlock Text="{Binding Label}"
                                                               Foreground="#0F172A"
                                                               FontSize="15"
                                                               FontWeight="SemiBold"
                                                               FontFamily="Consolas"
                                                               TextWrapping="Wrap"
                                                               LineHeight="24" />
                                                </Border>
                                            </Canvas>
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                            </Grid>

                            <Grid Style="{StaticResource DailyTableVisibilityStyle}">
                                <DataGrid ItemsSource="{Binding DailyKLines}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="日期" Binding="{Binding Date, StringFormat=yyyy-MM-dd}" Width="*" />
                                        <DataGridTextColumn Header="开盘" Binding="{Binding Open}" Width="*" />
                                        <DataGridTextColumn Header="最高" Binding="{Binding High}" Width="*" />
                                        <DataGridTextColumn Header="最低" Binding="{Binding Low}" Width="*" />
                                        <DataGridTextColumn Header="收盘" Binding="{Binding Close}" Width="*" />
                                        <DataGridTextColumn Header="成交量" Binding="{Binding Volume}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="新闻动态">
                    <Grid Margin="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="公司新闻"
                                           Style="{StaticResource SectionTitleStyle}" />
                                <ListBox Grid.Row="1"
                                         Margin="0,12,0,0"
                                         ItemsSource="{Binding CompanyNewsItems}"
                                         Background="Transparent"
                                         BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10"
                                                    Padding="12"
                                                    Background="White"
                                                    BorderBrush="#E2E8F0"
                                                    BorderThickness="1"
                                                    CornerRadius="12">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding PublishTime, StringFormat=yyyy-MM-dd HH:mm}"
                                                               Foreground="#64748B"
                                                               FontSize="11" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               FontSize="13"
                                                               TextWrapping="Wrap">
                                                        <Hyperlink NavigateUri="{Binding Url}" RequestNavigate="NewsLink_RequestNavigate">
                                                            <Run Text="{Binding Title}" />
                                                        </Hyperlink>
                                                    </TextBlock>
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="{Binding Source}"
                                                               Foreground="#0F766E"
                                                               FontSize="12" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="{Binding Summary}"
                                                               TextWrapping="Wrap"
                                                               Foreground="#334155"
                                                               FontSize="12" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                                Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="行业新闻"
                                           Style="{StaticResource SectionTitleStyle}" />
                                <ListBox Grid.Row="1"
                                         Margin="0,12,0,0"
                                         ItemsSource="{Binding IndustryNewsItems}"
                                         Background="Transparent"
                                         BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10"
                                                    Padding="12"
                                                    Background="White"
                                                    BorderBrush="#E2E8F0"
                                                    BorderThickness="1"
                                                    CornerRadius="12">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding PublishTime, StringFormat=yyyy-MM-dd HH:mm}"
                                                               Foreground="#64748B"
                                                               FontSize="11" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               FontSize="13"
                                                               TextWrapping="Wrap">
                                                        <Hyperlink NavigateUri="{Binding Url}" RequestNavigate="NewsLink_RequestNavigate">
                                                            <Run Text="{Binding Title}" />
                                                        </Hyperlink>
                                                    </TextBlock>
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="{Binding Source}"
                                                               Foreground="#0F766E"
                                                               FontSize="12" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="{Binding Summary}"
                                                               TextWrapping="Wrap"
                                                               Foreground="#334155"
                                                               FontSize="12" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="财务情况">
                    <Grid Margin="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14"
                                Margin="0,0,0,10">
                            <TextBlock Text="{Binding MetricsSummary}"
                                       TextWrapping="Wrap"
                                       Foreground="#0F172A"
                                       FontSize="13" />
                        </Border>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding FinancialHistoryItems}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="报告期" Binding="{Binding ReportDate, StringFormat=yyyy-MM-dd}" Width="*" />
                                <DataGridTextColumn Header="ROE" Binding="{Binding ROE, StringFormat=F2}" Width="*" />
                                <DataGridTextColumn Header="ROA" Binding="{Binding ROA, StringFormat=F2}" Width="*" />
                                <DataGridTextColumn Header="毛利率" Binding="{Binding GrossMargin, StringFormat=F2}" Width="*" />
                                <DataGridTextColumn Header="净利率" Binding="{Binding NetMargin, StringFormat=F2}" Width="*" />
                                <DataGridTextColumn Header="营收增长" Binding="{Binding RevenueGrowth, StringFormat=F2}" Width="*" />
                                <DataGridTextColumn Header="净利增长" Binding="{Binding ProfitGrowth, StringFormat=F2}" Width="*" />
                                <DataGridTextColumn Header="资产负债率" Binding="{Binding DebtRatio, StringFormat=F2}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
        </Grid>
    </Grid>
</Window>
