                                                        <Canvas />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style BasedOn="{StaticResource CanvasTickContainerStyle}" TargetType="ContentPresenter" />
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Label}" Foreground="#334155" FontSize="12" FontWeight="SemiBold" />
                                                    </DataTemplate>
