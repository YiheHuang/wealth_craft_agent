# LLM
OPENAI_API_KEY=your_openai_or_proxy_key_here
OPENAI_ENDPOINT=https://yunwu.ai/v1
OPENAI_MODEL=gpt-4o-mini

# Data source
INVEST_DATA_SOURCE=composite

# Optional API keys
ALPHAVANTAGE_API_KEY=your_alpha_vantage_key_here
FINNHUB_API_KEY=your_finnhub_key_here

# Optional switches
ALPHAVANTAGE_ENABLED=true
FINNHUB_ENABLED=false
